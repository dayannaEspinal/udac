<section class="eventos">

  <h2>{{eventos.title}}</h2>
  <p class="subtitle">{{eventos.subtitle}}</p>

  <div class="grid">

    {{#each eventos.items}}
    <div class="card">

      <div class="img-box">
        <img src="{{this.image}}" alt="evento">
      </div>

      <div class="info">
        <h3>{{this.title}}</h3>
        <p>{{this.desc}}</p>

        <div class="meta">
          <span>📅 {{this.date}}</span>
          <span>📍 {{this.location}}</span>
        </div>
      </div>

    </div>
    {{/each}}

  </div>

  <div class="info-extra">

    {{#each eventos.extra}}
    <div class="box">
      <h3>{{this.title}}</h3>
      <p>{{this.text}}</p>
    </div>
    {{/each}}

  </div>

  <div class="video-section">

    <h3>Conoce nuestras actividades</h3>

    <iframe 
      src="{{eventos.video}}" 
      frameborder="0" 
      allowfullscreen>
    </iframe>

  </div>

</section>