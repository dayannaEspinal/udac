<section class="eventos">

  <h2>{{eventos.title}}</h2>
  <p class="subtitle">{{eventos.subtitle}}</p>

  <div class="grid">

    {{#each eventos.items}}
    <div class="card">

      <div class="img-box">
        <img src="{{this.image}}" alt="evento">
      </div>

      <div class="info">

        <h3>{{this.title}}</h3>

        <p>{{this.desc}}</p>

        <div class="meta">
          <span>📅 {{this.date}}</span>
          <span>📍 {{this.location}}</span>
        </div>

      </div>

    </div>
    {{/each}}

  </div>

  <div class="info-extra">

    <div class="box">
      <h3>Impacto Social</h3>
      <p>Nuestros eventos buscan generar conciencia ambiental y participación comunitaria activa.</p>
    </div>

    <div class="box">
      <h3>Objetivo</h3>
      <p>Promover la sostenibilidad, educación ambiental y protección de recursos naturales.</p>
    </div>

  </div>

  <div class="video-section">

    <h3>Conoce nuestras actividades</h3>

    <iframe src="{{eventos.video}}" allowfullscreen></iframe>

  </div>

</section>