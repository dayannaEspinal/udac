<section class="eventos">

  <h2>{{eventos.title}}</h2>
  <p class="subtitle">{{eventos.subtitle}}</p>

  <div class="grid">

    {{#each eventos.items}}
    <div class="card">

      <div class="img-box">
        <img src="{{this.image}}" alt="{{this.title}}">
      </div>

      <div class="info">
        <h3>{{this.title}}</h3>
        <p>{{this.desc}}</p>

        <div class="meta">
          <span>{{this.date}}</span>
          <span>{{this.location}}</span>
        </div>
      </div>

    </div>
    {{/each}}

  </div>

  <!-- ENLACES -->
  <div class="links">
    <h3>Explora más</h3>

    <div class="link-box">
      {{#each eventos.links}}

        {{#if this.external}}
          <a href="{{this.url}}" class="btn" target="_blank">
            {{this.text}}
          </a>
        {{else}}
          <a href="{{this.url}}" class="btn">
            {{this.text}}
          </a>
        {{/if}}

      {{/each}}
    </div>
  </div>

  <!-- VIDEO -->
  <div class="video-section">
    <h3>Conoce nuestras actividades</h3>

    <iframe 
      src="{{eventos.video}}" 
      frameborder="0" 
      allowfullscreen>
    </iframe>

  </div>

</section>