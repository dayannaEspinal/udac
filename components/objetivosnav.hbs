<section class="objetivosflow">
  <div class="objetivosflow-header">
    <h2>{{objetivosSection.title}}</h2>
    <p>{{objetivosSection.description}}</p>
  </div>

  <div class="objetivosflow-grid">
    {{#each objetivosSection.items}}
      <article class="objetivosflow-card">
        <div class="objetivosflow-icon">
          <img src="{{icon}}" alt="{{title}}">
        </div>
        <h3>{{title}}</h3>
        <div class="objetivosflow-content">
          <p>{{text}}</p>
        </div>
      </article>
    {{/each}}
  </div>

  <div class="objetivosnav-gallery-header">
    <h3>{{objetivosSection.gallery.title}}</h3>
    <p>{{objetivosSection.gallery.description}}</p>
  </div>

  <div class="objetivosnav-gallery-scroll">
    {{#each objetivosSection.gallery.items}}
      <article class="objetivosnav-gallery-card">
        <div class="objetivosnav-gallery-image">
          <img src="{{image}}" alt="{{title}}">
        </div>
        <div class="objetivosnav-gallery-content">
          <span class="objetivosnav-gallery-category">{{category}}</span>
          <h4>{{title}}</h4>
          <p>{{text}}</p>
        </div>
      </article>
    {{/each}}
  </div>
</section>