<section class="contactanos">
  <div class="container">
    <h2>{{contact.sectionTitle}}</h2>
    <p class="subtitle">{{contact.sectionSubtitle}}</p>

    <div class="info-cards-container">
      
      <div class="info-card">
        <div class="icon-container">📞</div>
        <h4>Teléfonos</h4>
        {{#each contact.contactInfo.phones}}
          <p>{{this}}</p>
        {{/each}}
      </div>

      <div class="info-card">
        <div class="icon-container">✉️</div>
        <h4>Correo Electrónico</h4>
        {{#each contact.contactInfo.emails}}
          <p>{{this}}</p>
        {{/each}}
      </div>

      <div class="info-card">
        <div class="icon-container">📍</div>
        <h4>Dirección</h4>
        {{#each contact.contactInfo.address}}
          <p>{{this}}</p>
        {{/each}}
      </div>

      <div class="info-card">
        <div class="icon-container">🕒</div>
        <h4>Horarios de Atención</h4>
        {{#each contact.contactInfo.hours}}
          <p>{{this}}</p>
        {{/each}}
      </div>

    </div>
  </div>
</section>