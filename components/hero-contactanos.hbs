<section class="hero-page-detailed" style="background-image: linear-gradient(rgba(13, 74, 43, 0.8), rgba(13, 74, 43, 0.8)), url('{{heroContactanos.image}}');">
  <div class="container hero-detailed-grid">
    
    <div class="hero-main-info">
      <h1>{{heroContactanos.title}}</h1>
      <p class="main-subtitle">{{heroContactanos.subtitle}}</p>
    </div>

    <div class="hero-profile-card">
      <div class="profile-image-container">
        <img src="{{heroContactanos.profile.image}}" alt="{{heroContactanos.profile.name}}">
        <span class="profile-tag">{{heroContactanos.profile.tag}}</span>
      </div>
      <div class="profile-info">
        <h3>{{heroContactanos.profile.name}}</h3>
        <h4>{{heroContactanos.profile.role}}</h4>
        <p>{{heroContactanos.profile.description}}</p>
        <div class="profile-contact">
          <p><span class="icon">@</span> {{heroContactanos.profile.email}}</p>
          <p><span class="icon">📞</span> {{heroContactanos.profile.phone}}</p>
        </div>
      </div>
    </div>

  </div>
</section>