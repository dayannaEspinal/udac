<section class="nosotros">

  <section class="unidad-franja">

    <div class="unidad-content">

      <h2>{{nosotros.intro.title}}</h2>
      <p class="main-text">{{nosotros.intro.text}}</p>
      <p class="secondary-text">{{nosotros.intro.text2}}</p>

    </div>

  </section>

  <div class="mision-vision">

    <div class="box">
      <h3>Misión</h3>
      <p>{{nosotros.misionVision.mision}}</p>
    </div>

    <div class="box">
      <h3>Visión</h3>
      <p>{{nosotros.misionVision.vision}}</p>
    </div>

  </div>
  <div class="carousel-wrapper">

    <button class="carousel-btn left" onclick="moveCarousel(-1)">‹</button>

    <div class="carousel" id="carousel">

      {{#each nosotros.proyectos}}
      <div class="card">

        <img src="{{this.image}}" alt="proyecto">

        <div class="info">
          <h3>{{this.title}}</h3>
          <p>{{this.desc}}</p>
        </div>

      </div>
      {{/each}}

    </div>

    <button class="carousel-btn right" onclick="moveCarousel(1)">›</button>

  </div>

</section>