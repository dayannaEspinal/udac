<section class="cards-section" id="servicios">
  <div class="container">
    <h2 class="section-title">Nuestros Servicios</h2>
    <div class="cards-grid">
      {{#each cards}}
        <article class="card">
          <img src="{{image}}" alt="{{alt}}">
          <h3>{{title}}</h3>
          <p>{{text}}</p>
        </article>
      {{/each}}
    </div>
  </div>
</section>